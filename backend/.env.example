# MongoDB connection string
# Format: mongodb://username:password@host:port/database
# For local MongoDB: mongodb://localhost:27017/primetrade
# For MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/primetrade
MONGO_URI=mongodb://localhost:27017/primetrade

# JWT secret key (generate a strong random string)
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here

# JWT token expiration (e.g., 1h, 24h, 7d)
JWT_EXPIRES_IN=1h

# Frontend origin for CORS (your frontend URL)
FRONTEND_ORIGIN=http://127.0.0.1:5500

# Environment (development, production)
NODE_ENV=development

# Port to run the server on
PORT=5000
